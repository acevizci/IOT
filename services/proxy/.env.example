# install-proxy.sh bu dosyayı otomatik üretir -- elle kurulum yapıyorsan bunu
# .env olarak kopyalayıp doldur.

# Merkezin (gateway) adresi -- core-service'e DEĞİL, gateway'e işaret etmeli
# (core-service dışarıya hiç açık değildir, sadece gateway üzerinden erişilir).
CORE_URL=https://core.sirket.internal:8080

# Dashboard'daki "Proxy Kurulumu" sayfasında üretilen tek kullanımlık token.
# İlk başarılı kayıttan sonra bir daha kullanılmaz.
REGISTRATION_TOKEN=

# Bu proxy'nin temsil ettiği site adı (Dashboard'da bununla görünür).
PROXY_NAME=

# Merkezden/agent'lardan bu proxy'ye ulaşılacak adres (host:port) -- boş
# bırakılırsa Dashboard'dan sonradan girilebilir.
PROXY_ADDRESS=

# Host'a yayınlanan port (container içi her zaman sabit 8090'dır).
PROXY_HOST_PORT=8090

# Proxy'nin kendi yerel Postgres'inin şifresi -- install-proxy.sh rastgele üretir.
POSTGRES_PASSWORD=

# Farklı bir registry/tag kullanmak istersen (bkz. docker-compose.yml'deki not).
PROXY_IMAGE=ghcr.io/acevizci/iot-observability-proxy:latest
